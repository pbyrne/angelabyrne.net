{% if page.url.startsWith("/products") %}
<h2>Want me to make this for you?</h2>
{% else %}
<h2>Want me to make something for you?</h2>
{% endif %}

<form data-netlify="true" class="contact">

  <fieldset>
    <legend>Tell me about yourself</legend>

    <label for="form_name">Name</label>
    <input type="text" required id="form_name" name="name" placeholder="Your name">

    <label for="form_email">Email</label>
    <input type="email" required id="form_email" name="email" placeholder="Your name">

  </fieldset>

  <fieldset>
    <legend>Tell me what you're interested in</legend>

    <label for="form_product">Product</label>
    <select id="form_product" name="product">
      <option value="" disabled selected>Choose a product</option>
      {% for product in products %}
        <option value="{{ product.name }}">{{ product.name }}</option>
      {% endfor %}
    </select>

    <label for="form_message">Additional details</label>
    <textarea id="form_message" name="message" placeholder="Any additional details you can provide to help make the best craft for you." rows="4"></textarea>

  </fieldset>

  <fieldset>
    <input type="submit" value="Submit">
  </fieldset>
</form>
